# RISEx Tracker environment

# Base URL of the RISEx Analytics API (risex-api). Production: https://api.risescan.io
RISEX_API_URL=https://api.risescan.io

# Bearer key for the upstream API. Injected server-side by the proxy
# (app/api/proxy) so it never reaches the browser. Leave empty if the
# upstream has auth disabled.
RISEX_API_KEY=

# Set to 1 to serve deterministic mock data instead of calling the upstream
# API — useful for local UI work, review, and the Playwright suite.
RISEX_API_MOCK=0
